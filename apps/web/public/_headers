# Cloudflare Pages security headers (docs 9.5). Copied verbatim into dist/ by Vite.
# The CSP mirrors the <meta> CSP injected into index.html at build time. Same-origin
# deploys (Caddy/Pages proxying the API) work under connect-src 'self'; if the API is
# served from another origin, add it to connect-src here AND in vite.config.ts.
/*
  Content-Security-Policy: default-src 'none'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' wss://*.privex.chat; img-src 'self' blob: data:; style-src 'self'; font-src 'self'; worker-src 'self' blob:; manifest-src 'self'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
