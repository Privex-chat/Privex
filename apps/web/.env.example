# apps/web environment - copy to .env and adjust. NEVER commit .env.

# Backend (Rust server) the dev proxy forwards to. The app always uses relative
# same-origin paths, so the dev proxy handles routing and no CORS is needed.
# Examples: http://localhost:8080  |  http://192.168.1.50:8080
VITE_BACKEND_URL=http://localhost:8080

# Dev server port (Vite). Default 3000.
VITE_DEV_PORT=3000

# Pinned Key-Transparency signing public key. MUST match the running server's
# KT_SIGNING_KEY pubkey, which the server logs at startup:
#   INFO privex_server: kt_signer kt_signing_pub=<hex>
# Pinning it out-of-band is the whole point - never fetch it from the server.
VITE_KT_SIGNING_PUB=

# Optional: absolute backend URL the BUILT/deployed app talks to directly
# (bypasses the dev proxy → the server must send CORS headers, and the WebSocket
# is derived from this: http→ws, https→wss). Leave unset in dev.
# VITE_API_BASE=https://api.example.com
