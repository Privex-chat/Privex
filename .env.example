# =============================================================================
# Privex Server — Environment Configuration
# =============================================================================
# Copy to .env and fill in all values. Generate secrets with:
#   openssl rand -hex 32
# =============================================================================

# --- Server ---
BIND_ADDR=0.0.0.0:8888

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://privex:CHANGE_ME@127.0.0.1:5432/privex

# --- Cache (Redis) ---
REDIS_URL=redis://127.0.0.1:6380

# --- Session HMAC key (32 bytes hex) ---
# openssl rand -hex 32
SESSION_HMAC_KEY=

# --- Key Transparency signing key (32 bytes hex, Ed25519 seed) ---
# openssl rand -hex 32
KT_SIGNING_KEY=

# --- Delivery timestamp signing key (32 bytes hex, Ed25519 seed) ---
# openssl rand -hex 32
TIME_SIGNING_KEY=

# --- OPAQUE server setup (base64) ---
# Generated by first run of the opaque-ke setup tool.
OPAQUE_SERVER_SETUP=

# --- Proof-of-Work ---
POW_DIFFICULTY=22

# --- WebSocket ---
WS_PING_SECS=30

# --- Object storage (MinIO / S3-compatible) ---
R2_BUCKET=privex-files
R2_ENDPOINT=http://127.0.0.1:9000
R2_REGION=us-east-1
R2_ACCESS_KEY=privex
R2_SECRET_KEY=

# --- File uploads ---
FILE_UPLOADS_ENABLED=true

# --- TURN relay (optional in Phase 1) ---
TURN_SECRET=

# --- CORS ---
CORS_ORIGIN=https://privex.dpdns.org
WS_ALLOWED_ORIGINS=https://privex.dpdns.org
