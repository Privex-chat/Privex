# Privex environment - copy to .env and fill. NEVER commit .env.
# All server secrets load from env only (no plaintext secrets in code).

# --- Database (PostgreSQL 16) ---
DATABASE_URL=postgres://privex:privex@localhost:5432/privex

# --- Cache (Redis 7.2, no persistence) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (REQUIRED - Cloudflare R2 in prod, MinIO locally) ---
# Local MinIO:  R2_ENDPOINT=http://localhost:9000  R2_REGION=us-east-1
#               R2_ACCESS_KEY=privex  R2_SECRET_KEY=privexprivex
R2_BUCKET=privex-blobs
R2_ACCESS_KEY=replace-me
R2_SECRET_KEY=replace-me
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_REGION=auto

# --- Auth / sessions ---
# 32-byte key, HEX ONLY (64 hex chars). Generate: openssl rand -hex 32
SESSION_HMAC_KEY=replace-with-64-hex-chars

# Ed25519 seed for signing KT log roots. 32-byte hex. Generate: openssl rand -hex 32
KT_SIGNING_KEY=replace-with-64-hex-chars

# OPAQUE server long-term setup (base64 of a serialized ServerSetup). Generate
# ONCE offline and keep stable - rotating it invalidates all recovery records.
OPAQUE_SERVER_SETUP=replace-with-base64-serversetup

# --- TURN (Phase 3 calls) ---
TURN_SECRET=replace-me

# --- Server ---
BIND_ADDR=0.0.0.0:8080
RUST_LOG=info

# --- WebSocket Origin allowlist ---
# Comma-separated list of allowed Origin headers for WebSocket upgrades.
# Empty (or unset) = allow all origins (local dev default).
# Production: WS_ALLOWED_ORIGINS=https://privex.dpdns.org
# WS_ALLOWED_ORIGINS=
